# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://YOUR-FRONTEND-URL
AUTH_URL=https://YOUR-FRONTEND-URL
AUTH_TRUST_HOST=true

# Database (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Redis (required by Socket.io matchmaking — e.g. Upstash / Render Redis)
REDIS_URL=redis://DEFAULT:PASSWORD@HOST:6379

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=GENERATE_A_LONG_RANDOM_SECRET

# OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Cloudflare Turnstile (optional but recommended for public launch)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Socket.io signaling (Render)
NEXT_PUBLIC_SOCKET_URL=https://YOUR-SOCKET-SERVER-URL
SOCKET_PORT=3001
PORT=3001
ALLOWED_ORIGINS=https://YOUR-FRONTEND-URL

# WebRTC — STUN (public) + optional TURN (prefer server-side TURN_* for credentials)
NEXT_PUBLIC_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302
TURN_URL=turn:YOUR-TURN-SERVER:3478
TURNS_URL=turns:YOUR-TURN-SERVER:5349
TURN_USERNAME=REPLACE_ME
TURN_PASSWORD=REPLACE_ME
# Metered.ca / Open Relay (preferred free-tier TURN via /api/ice)
# Sign up at https://www.metered.ca/tools/openrelay/ (or Metered dashboard),
# then set domain like "yourapp.metered.live" and the credential API key.
# Do NOT commit real keys. Without TURN, cross-NAT video often stays black.
METERED_DOMAIN=
METERED_TURN_API_KEY=
# Legacy client-exposed TURN (discouraged — use /api/ice + TURN_* instead)
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Bootstrap admin allowlist (server-only). Database role remains primary.
ADMIN_EMAILS=rexdancer@beartv.com
