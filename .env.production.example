NODE_ENV=production

# Public HTTPS URLs (Cloudflare Tunnel / Tailscale Funnel hostname)
NEXT_PUBLIC_APP_URL=https://YOUR-TUNNEL-HOSTNAME
AUTH_URL=https://YOUR-TUNNEL-HOSTNAME
NEXT_PUBLIC_SOCKET_URL=https://YOUR-TUNNEL-HOSTNAME
ALLOWED_ORIGINS=https://YOUR-TUNNEL-HOSTNAME
AUTH_TRUST_HOST=true

# Generate: openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Internal Docker Postgres (compose sets host `postgres`)
POSTGRES_USER=beartv
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=beartv
DATABASE_URL=postgresql://beartv:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/beartv?schema=public

ADMIN_EMAILS=rexdancer@beartv.com

NEXT_PUBLIC_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Optional TURN — Metered/Open Relay (recommended for cross-NAT)
METERED_DOMAIN=
METERED_TURN_API_KEY=
# Or static Coturn / NAS TURN (bandwidth heavy)
TURN_URL=
TURNS_URL=
TURN_USERNAME=
TURN_PASSWORD=

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
